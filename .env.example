# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ───────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
# Local:  postgresql://postgres:yourpassword@localhost:5432/businessos
# Neon:   postgresql://user:password@host.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host/dbname

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use any long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
